# Prefix — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL (local dev with Docker: docker run -e POSTGRES_PASSWORD=password -p 5432:5432 postgres:16)
DATABASE_URL="postgresql://prefix:password@localhost:5432/prefix?schema=public"

# Clerk Authentication (get these from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx

# Clerk redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# KEV API (public, no key needed)
KEV_API_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# OSV.dev API (public, no key needed)
OSV_API_URL=https://api.osv.dev/v1

# ─── Reports / Signed URLs ──────────────────────────────────────────────────
# HMAC secret for expiring report share links (7-day default).
# Falls back to CLERK_SECRET_KEY if not set. Set this in production.
REPORT_SECRET=

# ─── LLM Provider Router ────────────────────────────────────────────────────
# Set LLM_PROVIDER to select which backend to use.
# Set LLM_FALLBACK_PROVIDER to auto-retry on failure.
#
# Provider options:
#   anthropic         → Claude via Anthropic API (Claude Code Pro subscription works here)
#   openai-compatible → Ollama, vLLM, LiteLLM, or any OpenAI-style endpoint (LOCAL, FREE)
#   nvidia            → NVIDIA NIM / build.nvidia.com (FREE tier available)
#   groq              → Groq cloud (FREE tier — fast Llama/Mixtral inference)
#   openrouter        → OpenRouter broker (FREE models available with :free suffix)
#   together          → Together AI (free credits on signup)
#   xai               → xAI Grok
#   huggingface       → Hugging Face Inference API

LLM_PROVIDER=nvidia
LLM_MODEL=meta/llama-3.1-70b-instruct
LLM_FALLBACK_PROVIDER=openai-compatible
LLM_FALLBACK_MODEL=llama3.2

# ─── Anthropic / Claude ─────────────────────────────────────────────────────
# Claude Code Pro users: ANTHROPIC_API_KEY is auto-injected by the CLI.
# Direct API users: get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── NVIDIA NIM (FREE tier at https://build.nvidia.com) ─────────────────────
NVIDIA_API_KEY=nvapi_xxxxxxxx
# Override for self-hosted NIM deployment:
NVIDIA_NIM_API_BASE=

# ─── OpenAI-compatible (Ollama local — FREE, no key needed) ─────────────────
# Point at Ollama: http://localhost:11434/v1
# Or any vLLM / LiteLLM / LocalAI / custom proxy endpoint
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.2

# Local self-hosted override (takes precedence over OPENAI_* above)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# ─── Groq (FREE tier — https://console.groq.com) ────────────────────────────
GROQ_API_KEY=

# ─── OpenRouter (FREE models — https://openrouter.ai) ───────────────────────
# Free models use :free suffix e.g. meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=

# ─── Together AI (free credits on signup — https://api.together.ai) ─────────
TOGETHER_API_KEY=

# ─── Google Gemini (FREE tier — https://aistudio.google.com) ────────────────
GEMINI_API_KEY=

# ─── xAI Grok (https://console.x.ai) ───────────────────────────────────────
XAI_API_KEY=

# ─── Hugging Face Inference (https://huggingface.co/settings/tokens) ────────
HUGGINGFACE_API_KEY=
